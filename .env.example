# ──────────────────────────────────────────────────────────────────────
# Music Library — deployment config
#
# Copy this file to `.env` and fill in the required values, then run:
#   docker compose up -d
# ──────────────────────────────────────────────────────────────────────

# Loopback ports the compose stack exposes on the host. A reverse proxy
# (nginx, …) on this host connects to these.
BACKEND_PORT=8080
FRONTEND_PORT=8081
POSTGRES_PORT=5432

# Postgres
POSTGRES_USER=mlib
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mlib

# First-run admin. If ADMIN_PASSWORD is empty the backend generates a
# random one and logs it on first boot.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Sessions
SESSION_COOKIE=mlsession
# Leave COOKIE_SECURE=true when behind HTTPS. Set to false only for
# plain-HTTP local dev.
COOKIE_SECURE=true
SESSION_TTL=720h
# Stable hex-encoded HMAC key for signed cover/share/preview URLs.
# Generate with: openssl rand -hex 32
COVER_SIGN_KEY=CHANGE_ME_64_HEX_CHARS

# Music library location on the host. Bind-mounted into the backend at the
# SAME path inside the container, so music roots you add in the admin UI use
# the identical path the host uses. Accepts absolute paths.
MUSIC_HOST_PATH=/mnt/music

# Host group GID that owns the music directory — the backend container joins
# it to read/write the bind mount (check with: stat -c %g /mnt/music).
MUSIC_GROUP_GID=1100

# Filen share scanner. The backend image includes Node and the bundled helper.
# Override only for local development with a custom helper path.
FILEN_SCAN_POLL_INTERVAL=5m
FILEN_FILE_TIMEOUT=30m

# Transcoding is off by default. Enable only if you need client-profile
# transcoding — the backend image already ships ffmpeg.
ENABLE_TRANSCODING=false

# CIDR ranges whose X-Forwarded-* headers the backend should trust. When a
# host-level nginx proxies to the backend through the Docker bridge, the
# request reaches the backend from the bridge gateway — trust the default
# Docker bridge range so real client IPs are preserved.
TRUSTED_PROXIES=172.16.0.0/12
