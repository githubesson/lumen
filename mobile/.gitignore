# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Generated by scripts/sync-core-package.mjs (postinstall) from the canonical
# ../core. Do NOT edit or commit — it's a build artifact; the single source
# of truth is the sibling core package.
/packages/music-library-core/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Personal EAS config (project/app IDs, TestFlight workflow). Regenerate
# eas.json with `npm run configure`.
/eas.json
/.eas/

# Personal overlay deep-merged over app.json by app.config.js — keeps your
# owner / bundle id / API URL / EAS ids out of the repo.
/app.local.json

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
