{
  "expo": {
    "name": "Lumen",
    "slug": "music-library-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "musiclibrarymobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Lumen needs photo library access to set album cover art and to hand music story media to Instagram.",
        "NSCameraUsageDescription": "Lumen needs camera permission only because sharing libraries may reference camera APIs while preparing Instagram story media.",
        "NSLocalNetworkUsageDescription": "Lumen needs local network access to connect to the development server on your Mac.",
        "NSBonjourServices": [
          "_expo._tcp",
          "_react-native-packager._tcp"
        ]
      },
      "bundleIdentifier": "com.example.lumen"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withExpoModulesCoreSwiftWorkaround",
      "./plugins/withInstagramStorySharing",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "extra": {
      "apiBaseUrl": "",
      "instagramAppId": "",
      "router": {}
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
