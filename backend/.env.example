HTTP_ADDR=:8080
DATABASE_URL=postgres://mlib:mlib@postgres:5432/mlib?sslmode=disable

MUSIC_PATH=/music
TRANSCODE_CACHE=/cache
ENABLE_TRANSCODING=false

# Tracker-API instance for the default scanner client. Blank uses the
# canonical public instance (see internal/apitracker DefaultBaseURL); each
# pin can also set its own api_base_url.
API_TRACKER_BASE_URL=
API_TRACKER_SCAN_POLL_INTERVAL=5m
API_TRACKER_FILE_TIMEOUT=30m
ARTISTGRID_SCAN_POLL_INTERVAL=5m
ARTISTGRID_FILE_TIMEOUT=30m
FILEN_SCAN_POLL_INTERVAL=5m
FILEN_FILE_TIMEOUT=30m
# Local dev override only; Docker image sets this to the bundled helper.
FILEN_DOWNLOADER_SCRIPT=

# Seeded on first run if no users exist.
# If ADMIN_PASSWORD is empty, a random one is generated and logged.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

SESSION_COOKIE=mlsession
# Set to false when running behind plain HTTP in local dev.
COOKIE_SECURE=true
SESSION_TTL=720h

TRUSTED_PROXIES=
