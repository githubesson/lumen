{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./build",
    "rootDir": ".",
    "sourceMap": false,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["main.ts", "preload.ts", "mainPreload.ts"]
}
