{
  "name": "music-library-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/build/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "electron:compile": "node scripts/electron-buildenv.mjs && tsc -p electron/tsconfig.json && tsc -p electron/tsconfig.setup.json",
    "electron:dev": "npm run build && npm run electron:compile && electron .",
    "electron:build": "npm run build && npm run electron:compile && electron-builder --win --publish never --config electron-builder.yml"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.5",
    "@music-library/core": "file:../core",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "discord-rpc": "^4.0.1",
    "hls.js": "^1.6.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.3"
  }
}
